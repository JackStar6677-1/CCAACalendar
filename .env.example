APP_NAME=CCAACalendar
PUBLIC_BRAND_NAME=CCAACalendar
ENVIRONMENT=local
DATABASE_URL=sqlite:///./.local/ccaa_calendar.db
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://ccaa.drakescraft.cl
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CLIENT_SECRET_FILE=.local/google_oauth_client_secret.json
GOOGLE_REDIRECT_URI=http://localhost:8000/api/integrations/google/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.events
# Opcional: habilitar solo cuando se implementen recordatorios salientes por Gmail.
GOOGLE_GMAIL_SCOPES=
# Cuenta oficial del centro: definir solo en .env local o secreto del despliegue.
GOOGLE_CENTER_ACCOUNT_EMAIL=
GOOGLE_CALENDAR_ID=primary
APP_PUBLIC_URL=https://ccaa.drakescraft.cl
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=CCAACalendar · CE Psicología UDLA
MAIL_FALLBACK_CONSOLE=true
# SMTP opcional (tu correo personal u otro). Gmail del centro va por OAuth.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
GOOGLE_OAUTH_STATE_PATH=.local/google_oauth_state.json
GOOGLE_TOKEN_PATH=.local/google_token.json
ADMIN_ROSTER_PATH=.local/admin_roster.json
ADMIN_IDENTITY_PEPPER=change-this-local-secret
APP_LOG_PATH=.local/logs/ccaa-calendar.jsonl
# Recordatorios por correo: minutos antes del evento (24h y 1h por defecto)
EVENT_EMAIL_REMINDER_MINUTES=1440,60
EVENT_EMAIL_WORKER_INTERVAL_SECONDS=60
