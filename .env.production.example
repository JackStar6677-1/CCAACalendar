APP_NAME=CCAACalendar
PUBLIC_BRAND_NAME=CCAACalendar
ENVIRONMENT=production
DATABASE_URL=postgresql+psycopg://USUARIO:CLAVE@postgres:5432/ccaa_calendar
ALLOWED_ORIGINS=https://ccaa.drakescraft.cl
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CLIENT_SECRET_FILE=/run/secrets/google_oauth_client_secret.json
GOOGLE_REDIRECT_URI=https://ccaa.drakescraft.cl/api/integrations/google/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.events
# Permiso minimo para confirmaciones y recordatorios salientes.
GOOGLE_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.send
GOOGLE_CENTER_ACCOUNT_EMAIL=
GOOGLE_CALENDAR_ID=primary
APP_PUBLIC_URL=https://ccaa.drakescraft.cl
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=CCAACalendar - CE Psicologia UDLA
MAIL_FALLBACK_CONSOLE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
GOOGLE_OAUTH_STATE_PATH=/var/lib/ccaa-calendar/google_oauth_state.json
GOOGLE_TOKEN_PATH=/var/lib/ccaa-calendar/google_token.json
ADMIN_ROSTER_PATH=/run/secrets/admin_roster.json
ADMIN_IDENTITY_PEPPER=
PII_ENCRYPTION_KEYS=
PII_LOOKUP_PEPPER=
APP_LOG_PATH=/var/log/ccaa-calendar/app.jsonl
EVENT_EMAIL_REMINDER_MINUTES=1440,60
EVENT_EMAIL_WORKER_INTERVAL_SECONDS=60
